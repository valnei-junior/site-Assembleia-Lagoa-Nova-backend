PORT=5000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# JWT (producao: usar segredos longos e aleatorios)
JWT_SECRET=troque_este_segredo_em_producao
JWT_ACCESS_SECRET=troque_por_access_secret_forte
JWT_REFRESH_SECRET=troque_por_refresh_secret_forte
JWT_EXPIRES_IN=1d
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CAPTCHA
CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET_KEY=troque_por_captcha_secret
# Opcional (sobrescrevem CAPTCHA_SECRET_KEY por provedor)
TURNSTILE_SECRET_KEY=
RECAPTCHA_SECRET_KEY=

# Banco (opção 1: URL completa)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ad_lagoa_nova

# Banco (opção 2: campos separados)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ad_lagoa_nova
DB_USER=postgres
DB_PASSWORD=postgres

# Usuários iniciais
ADMIN_DEFAULT_EMAIL=admin@adlagoanova.local
ADMIN_DEFAULT_PASSWORD=admin123
PASTOR_DEFAULT_EMAIL=pastor@adlagoanova.local
PASTOR_DEFAULT_PASSWORD=pastor123
